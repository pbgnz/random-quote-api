# =========================
# 🌍 Server
# =========================
PORT=8000
APP_URL=http://localhost:8000

# =========================
# 🌐 CORS
# =========================
ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_NO_ORIGIN=true

# =========================
# 🧠 Cache
# =========================
CACHE_TTL_MINUTES=60
CACHE_MAX_ITEMS=500
CACHE_ENABLE_FALLBACK=true

# =========================
# 🕸 Scraper
# =========================
SCRAPER_TIMEOUT_MS=15000
SCRAPER_RETRIES=2
SCRAPER_MAX_PAGE=100
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; QuoteBot/1.0)

# =========================
# 🚦 Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# =========================
# 📊 Logging
# =========================
LOG_LEVEL=info
LOG_PRETTY=true

# =========================
# ⚙️ Feature Flags
# =========================
ENABLE_CACHE=true
ENABLE_COMPRESSION=true

# =========================
# 🛑 Resilience
# =========================
FALLBACK_MIN_QUOTES=5
SCRAPER_FAIL_SILENT=false