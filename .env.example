# =========================
# 🌍 Server
# =========================
PORT=8000
APP_URL=http://localhost:8000

# =========================
# 🌐 CORS
# =========================
ALLOWED_ORIGINS=http://localhost:3000

# =========================
# 🧠 Cache
# =========================
CACHE_TTL_MINUTES=60

# =========================
# 📊 Logging
# =========================
LOG_LEVEL=info

# =========================
# 🔧 Scraper Configuration
# =========================
SCRAPER_TIMEOUT_MS=15000
SCRAPER_RETRIES=2
SCRAPER_MAX_PAGE=100

# =========================
# 🚦 Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100